{
  "format_version": "1.21.130",
  "minecraft:entity": {
    "description": {
      "identifier": "mcblock:superhero_agent",
      "is_spawnable": true,
      "is_summonable": true,
      "is_experimental": false
    },
    "component_groups": {
      "mcblock:level_1": {
        "minecraft:health": { "value": 20, "max": 20 },
        "minecraft:attack": { "damage": 4 },
        "minecraft:movement": { "value": 0.32 }
      },
      "mcblock:level_2": {
        "minecraft:health": { "value": 30, "max": 30 },
        "minecraft:attack": { "damage": 6 },
        "minecraft:movement": { "value": 0.35 }
      },
      "mcblock:level_3": {
        "minecraft:health": { "value": 42, "max": 42 },
        "minecraft:attack": { "damage": 8 },
        "minecraft:movement": { "value": 0.38 }
      },
      "mcblock:level_4": {
        "minecraft:health": { "value": 60, "max": 60 },
        "minecraft:attack": { "damage": 11 },
        "minecraft:movement": { "value": 0.42 }
      },
      "mcblock:owned": {
        "minecraft:sittable": {},
        "minecraft:behavior.stay_while_sitting": { "priority": 1 },
        "minecraft:behavior.follow_owner": {
          "priority": 4,
          "speed_multiplier": 1.2,
          "start_distance": 5,
          "stop_distance": 2,
          "can_teleport": true
        },
        "minecraft:behavior.owner_hurt_by_target": {
          "priority": 2,
          "entity_types": [
            {
              "filters": {
                "test": "is_family",
                "subject": "other",
                "value": "monster"
              }
            }
          ]
        },
        "minecraft:behavior.owner_hurt_target": {
          "priority": 3,
          "entity_types": [
            {
              "filters": {
                "test": "is_family",
                "subject": "other",
                "value": "monster"
              }
            }
          ]
        }
      }
      ,
      "mcblock:mode_fight": {
        "minecraft:variant": { "value": 0 }
      },
      "mcblock:mode_defend": {
        "minecraft:variant": { "value": 1 }
      },
      "mcblock:mode_heal": {
        "minecraft:variant": { "value": 2 }
      }
    },
    "components": {
      "minecraft:type_family": { "family": ["superhero_agent", "mob", "player"] },
      "minecraft:health": { "value": 20, "max": 20 },
      "minecraft:attack": { "damage": 4 },
      "minecraft:movement": { "value": 0.32 },
      "minecraft:nameable": { "always_show": true },
      "minecraft:collision_box": { "width": 0.8, "height": 0.8 },
      "minecraft:physics": { "has_gravity": false, "has_collision": true },
      "minecraft:pushable": { "is_pushable": true, "is_pushable_by_piston": true },
      "minecraft:can_fly": {},
      "minecraft:movement.hover": {},
      "minecraft:navigation.fly": {
        "avoid_water": true,
        "can_path_over_water": true
      },
      "minecraft:tameable": {
        "probability": 1.0,
        "tame_items": ["minecraft:apple"],
        "tame_event": { "event": "mcblock:on_tame", "target": "self" }
      },
      "minecraft:healable": {
        "items": [
          { "item": "minecraft:bread", "heal_amount": 4 },
          { "item": "minecraft:cooked_beef", "heal_amount": 8 },
          { "item": "minecraft:golden_apple", "heal_amount": 16 }
        ]
      },
      "minecraft:interact": {
        "interactions": [
          {
            "interact_text": "Use Hero Core",
            "health_amount": 8,
            "on_interact": {
              "filters": {
                "all_of": [
                  {
                    "test": "has_equipment",
                    "subject": "other",
                    "domain": "hand",
                    "value": "mcblock:hero_core"
                  }
                ]
              },
              "event": "mcblock:core_use",
              "target": "self"
            },
            "particle_on_start": {
              "particle_type": "minecraft:totem_particle",
              "particle_y_offset": 0.6,
              "particle_offset_towards_interactor": true
            },
            "play_sounds": "random.levelup"
          },
          {
            "interact_text": "Install HP Chip",
            "on_interact": {
              "filters": { "all_of": [{ "test": "has_equipment", "subject": "other", "domain": "hand", "value": "mcblock:hero_hp_chip" }] },
              "event": "mcblock:hp_chip",
              "target": "self"
            },
            "use_item": true,
            "play_sounds": "random.levelup"
          },
          {
            "interact_text": "Install Strength Chip",
            "on_interact": {
              "filters": { "all_of": [{ "test": "has_equipment", "subject": "other", "domain": "hand", "value": "mcblock:hero_strength_chip" }] },
              "event": "mcblock:strength_chip",
              "target": "self"
            },
            "use_item": true,
            "play_sounds": "random.levelup"
          },
          {
            "interact_text": "Install Light Chip",
            "on_interact": {
              "filters": { "all_of": [{ "test": "has_equipment", "subject": "other", "domain": "hand", "value": "mcblock:hero_light_chip" }] },
              "event": "mcblock:light_chip",
              "target": "self"
            },
            "use_item": true,
            "play_sounds": "random.levelup"
          },
          {
            "interact_text": "Upgrade with Iron",
            "on_interact": {
              "filters": { "all_of": [{ "test": "has_equipment", "subject": "other", "domain": "hand", "value": "minecraft:iron_ingot" }] },
              "event": "mcblock:upgrade_level_2",
              "target": "self"
            },
            "use_item": true,
            "play_sounds": "random.levelup"
          },
          {
            "interact_text": "Upgrade with Gold",
            "on_interact": {
              "filters": { "all_of": [{ "test": "has_equipment", "subject": "other", "domain": "hand", "value": "minecraft:gold_ingot" }] },
              "event": "mcblock:upgrade_level_3",
              "target": "self"
            },
            "use_item": true,
            "play_sounds": "random.levelup"
          },
          {
            "interact_text": "Upgrade with Diamond",
            "on_interact": {
              "filters": { "all_of": [{ "test": "has_equipment", "subject": "other", "domain": "hand", "value": "minecraft:diamond" }] },
              "event": "mcblock:upgrade_level_4",
              "target": "self"
            },
            "use_item": true,
            "play_sounds": "random.levelup"
          }
        ]
      },
      "minecraft:behavior.float": { "priority": 0 },
      "minecraft:behavior.melee_attack": { "priority": 1, "speed_multiplier": 1.2, "track_target": true },
      "minecraft:behavior.hurt_by_target": { "priority": 2 },
      "minecraft:behavior.move_towards_target": {
        "priority": 2,
        "speed_multiplier": 1.1,
        "within_radius": 16
      },
      "minecraft:behavior.nearest_attackable_target": {
        "priority": 3,
        "reselect_targets": true,
        "within_radius": 16,
        "entity_types": [
          {
            "filters": { "test": "is_family", "subject": "other", "value": "monster" },
            "max_dist": 12
          }
        ]
      },
      "minecraft:behavior.random_look_around": { "priority": 8 }
    },
    "events": {
      "minecraft:entity_spawned": { "add": { "component_groups": ["mcblock:level_1", "mcblock:mode_fight"] } },
      "mcblock:on_tame": { "add": { "component_groups": ["mcblock:owned"] } },
      "mcblock:upgrade_level_2": {
        "remove": { "component_groups": ["mcblock:level_1", "mcblock:level_3", "mcblock:level_4"] },
        "add": { "component_groups": ["mcblock:level_2"] }
      },
      "mcblock:upgrade_level_3": {
        "remove": { "component_groups": ["mcblock:level_1", "mcblock:level_2", "mcblock:level_4"] },
        "add": { "component_groups": ["mcblock:level_3"] }
      },
      "mcblock:upgrade_level_4": {
        "remove": { "component_groups": ["mcblock:level_1", "mcblock:level_2", "mcblock:level_3"] },
        "add": { "component_groups": ["mcblock:level_4"] }
      },
      "mcblock:core_use": {
        "add": { "component_groups": ["mcblock:owned"] }
      },
      "mcblock:hp_chip": {
        "add": { "component_groups": ["mcblock:owned"] }
      },
      "mcblock:strength_chip": {
        "add": { "component_groups": ["mcblock:owned"] }
      },
      "mcblock:light_chip": {
        "add": { "component_groups": ["mcblock:owned"] }
      },
      "mcblock:set_fight": {
        "remove": { "component_groups": ["mcblock:mode_defend", "mcblock:mode_heal"] },
        "add": { "component_groups": ["mcblock:mode_fight"] }
      },
      "mcblock:set_defend": {
        "remove": { "component_groups": ["mcblock:mode_fight", "mcblock:mode_heal"] },
        "add": { "component_groups": ["mcblock:mode_defend"] }
      },
      "mcblock:set_heal": {
        "remove": { "component_groups": ["mcblock:mode_fight", "mcblock:mode_defend"] },
        "add": { "component_groups": ["mcblock:mode_heal"] }
      }
    }
  }
}
